# Copiez ce fichier vers .env ou .env.production puis remplissez les valeurs.
# Commandes utiles : npx @insforge/cli current
#                     npx @insforge/cli secrets get ANON_KEY
# Sur Vercel, l’URL peut s’appeler VITE_INSFORGE_BASE_URL (reconnue aussi par l’app).

VITE_INSFORGE_URL=https://VOTRE-APPKEY.REGION.insforge.app
# VITE_INSFORGE_BASE_URL=https://...   # alternative (ex. Vercel)
VITE_INSFORGE_ANON_KEY=
